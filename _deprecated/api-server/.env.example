# MongoDB connection string. Local dev: a MongoDB Atlas free (M0) cluster or
# a local `mongodb://localhost:27017/corcodusa` both work. Production
# (Render): set this in the Render service's Environment tab to your Atlas
# connection string.
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/corcodusa

# Clerk — backend (read at runtime by the Express server)
# Get from https://dashboard.clerk.com/~/api-keys ("Quick Copy" section)
CLERK_PUBLISHABLE_KEY=pk_test_or_pk_live_xxx
CLERK_SECRET_KEY=sk_test_or_sk_live_xxx

# Required for clerkProxyMiddleware to activate. Only relevant if using the
# proxy approach instead of a clerk.* CNAME — see VITE_CLERK_PROXY_URL note
# in artifacts/corcodusa/.env.example.
NODE_ENV=production
