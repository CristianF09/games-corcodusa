# MongoDB connection string. Local dev: a MongoDB Atlas free (M0) cluster, or
# a local `mongodb://localhost:27017/corcodusa`, both work. This is the SAME
# database the Node.js backend used — collections/field names below were
# kept byte-for-byte compatible, so both backends can point at the same
# Atlas cluster during a transition.
MONGODB_URI=mongodb+srv://cristianflaurentiu:<db_password>@cluster0.emydjgo.mongodb.net/corcodusa?appName=Cluster0
# Clerk — backend (read at runtime by FastAPI, never bundled into a public file)
# Get from https://dashboard.clerk.com/~/api-keys ("Quick Copy" section)
CLERK_SECRET_KEY=sk_test_or_sk_live_xxx

# Stripe — backend secret key + webhook signing secret
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_or_sk_live_xxx
# Dashboard: https://dashboard.stripe.com/webhooks (created after you add the
# /api/stripe/webhook endpoint URL there)
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Base URL of the FRONTEND (not this API!) — Stripe checkout/portal redirects
# the user back here after payment (success_url/cancel_url/return_url point
# at frontend routes like /pricing, /dashboard). Production: the frontend
# is games.corcodusa.ro (Fir