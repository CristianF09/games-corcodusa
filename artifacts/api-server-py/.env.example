# MongoDB connection string. Include the database name in the URI path
# (the "/corcodusa" segment below) — without it, get_default_database()
# raises ConfigurationError on startup.  If your Render MONGODB_URI is a
# bare cluster URL without the db segment, add DB_NAME=corcodusa separately.
MONGODB_URI=mongodb+srv://cristianflaurentiu:<db_password>@cluster0.emydjgo.mongodb.net/corcodusa?appName=Cluster0
# Optional — only needed when MONGODB_URI has no /dbname segment (bare URI).
# DB_NAME=corcodusa
# Clerk — backend (read at runtime by FastAPI, never bundled into a public file)
# Get from https://dashboard.clerk.com/~/api-keys ("Quick Copy" section)
CLERK_SECRET_KEY=sk_test_or_sk_live_xxx

# Stripe — backend secret key + webhook signing secret
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_or_sk_live_xxx
# Dashboard: https://dashboard.stripe.com/webhooks (created after you add the
# /api/stripe/webhook endpoint URL there)
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Base URL of the FRONTEND (not this API!) — Stripe checkout/portal redirects
# the user back here after payment (success_url/cancel_url/return_url point
# at frontend routes like /pricing, /dashboard). Production: the frontend
# is games.corcodusa.ro (Firebase Hosting); this API's own domain is the
# separate games-api.corcodusa.ro, NOT api.corcodusa.ro (that one belongs to
# the unrelated corcodusa.ro PDF-delivery business). Local dev: the Vite
# dev server, http://localhost:5173.
APP_BASE_URL=http://localhost:5173

# Render injects PORT automatically — only set this for local dev.
PORT=8080

# Resend — sends purchase confirmation emails (checkout.session.completed
# webhook) AND the footer contact-form email (POST /api/contact).
# Dashboard: https://resend.com/api-keys
RESEND_API_KEY=re_xxx
# Must be on a domain you've verified in Resend (https://resend.com/domains).
# Until corcodusa.ro is verified there, leave this as the Resend sandbox
# sender (onboarding@resend.dev) — it works, but only delivers to the email
# address of the Resend account owner, not to arbitrary recipients.
CONTACT_EMAIL_FROM=C